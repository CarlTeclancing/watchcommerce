{
  "name": "watch-commerce/platform",
  "description": "Luxury watch commerce platform in pure PHP 8.3",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testdox",
    "migrate": "php scripts/migrate.php",
    "seed": "php scripts/seed.php"
  }
}